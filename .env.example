# Archivo de configuración de ejemplo para desarrollo local
# Copia este archivo a .env para configuraciones personalizadas

# CONFIGURACIÓN DE DESARROLLO
DEBUG=false
ENVIRONMENT=production

# CONFIGURACIÓN DE NETLIFY (opcional)
# Estas variables se pueden configurar en Netlify → Site settings → Environment
# NETLIFY_SITE_ID=tu-site-id-aqui
# NETLIFY_AUTH_TOKEN=tu-token-aqui

# Nota: Este proyecto no necesita variables de entorno especiales
# todo funciona offline después del primer load
